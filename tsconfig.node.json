{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "src/main/**/*",
    "src/preload/**/*",
    "src/shared/ipc/**/*",
    "src/features/**/main/**/*",
    "src/features/**/shared/**/*",
    "src/shared/**/*"
  ],
  "exclude": [
    "src/shared/shell/**/*",
    "src/shared/ui/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "types": ["electron-vite/node"],
    "baseUrl": ".",
    "paths": {
      "@features/*": ["src/features/*"],
      "@shared/*": ["src/shared/*"]
    }
  }
}
